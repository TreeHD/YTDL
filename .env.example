# Bot
BOT_TOKEN=your_bot_token_here
ALLOWED_CHAT_IDS=

# Telegram Local Bot API Server
API_URL=http://host.docker.internal:8081/bot
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Proxies for yt-dlp
PROXY_LIST=socks5://warpuser:warppass@warp-proxy:1080

# Cloudflare WARP Proxy
WARP_SOCKS_PORT=1080
WARP_HTTP_PORT=8080
WARP_RESTART_PORT=9090
WARP_USERNAME=warpuser
WARP_PASSWORD=warppass

# Limits
MAX_DISK_GB=10
SUBSCRIPTION_CHECK_INTERVAL=300
